{
  "name": "game-editor",
  "version": "0.1.0",
  "private": true,
  "description": "A Figma-like design platform (monorepo: React frontend + Express backend)",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w frontend",
    "dev:api": "cd backend && ./.venv/bin/python manage.py runserver 0.0.0.0:8000",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
