# Copy to .env for local development. Do NOT commit real secrets.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call the API (the frontend dev server).
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Postgres ---
POSTGRES_DB=game_editor
POSTGRES_USER=game_editor
POSTGRES_PASSWORD=game_editor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- AWS S3 (character image uploads) ---
# Fill these in with your real values. While any value contains "REPLACE_ME" (or is blank),
# the image endpoints report "not configured" instead of attempting an upload.
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET=REPLACE_ME-game-editor-characters
# Optional: a CloudFront/custom domain serving the bucket. Leave blank to use the default S3 URL.
AWS_S3_PUBLIC_BASE_URL=

# --- FLUX / fal.ai (AI character image generation) ---
# Get a key at https://fal.ai/dashboard/keys. FAL_IMAGE_MODEL can be any fal image model
# (fal-ai/flux/dev, fal-ai/flux/schnell, fal-ai/flux-pro/v1.1, …).
FAL_KEY=REPLACE_ME
FAL_IMAGE_MODEL=fal-ai/flux/dev
