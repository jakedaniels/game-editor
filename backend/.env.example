# Copy to .env for local development. Do NOT commit real secrets.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call the API (the frontend dev server).
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Postgres ---
POSTGRES_DB=game_editor
POSTGRES_USER=game_editor
POSTGRES_PASSWORD=game_editor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
